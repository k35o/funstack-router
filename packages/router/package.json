{
  "name": "@funstack/router",
  "version": "1.1.0",
  "description": "A modern React router based on the Navigation API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhyo/funstack-router.git",
    "directory": "packages/router"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "bin": {
    "funstack-router-skill-installer": "./dist/bin/skill-installer.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "build:docs": "node --experimental-strip-types scripts/generate-ai-docs.ts",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "router",
    "navigation-api"
  ],
  "author": "uhyo <uhyo@uhy.ooo>",
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "dependencies": {
    "@funstack/skill-installer": "^1.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "urlpattern-polyfill": "^10.1.0",
    "vitest": "^4.1.6"
  }
}
